{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build OS",
            "command": "make",
            "args": [
                "build"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "shell",
            "label": "Run OS",
            "command": "make",
            "args": [
                "run"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Build OS"
            ]
        },
        {
            "type": "shell",
            "label": "Launch QEMU Debug",
            "command": "qemu-system-i386",
            "args": [
                "-s",
                "-S",
                "-drive",
                "file=bin/storage.bin,format=raw,if=ide,index=0,media=disk",
                "-cdrom",
                "bin/OS2025.iso"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$"
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "."
                }
            }
        },
        {
            "type": "shell",
            "label": "Kill QEMU",
            "command": "pkill -f qemu || true",
            "windows": {
                "command": "taskkill /F /IM qemu-system-i386.exe || exit 0"
            }
        },
        {
            "type": "shell",
            "label": "Clean",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            }
        },
        {
            "type": "cppbuild",
            "label": "C/C++: gcc build active file",
            "command": "/usr/bin/gcc",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Task generated by Debugger."
        },
        {
            "type": "cppbuild",
            "label": "Build Inserter",
            "command": "make",
            "args": ["inserter"],
            "options": {"cwd": "${workspaceFolder}"},
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}